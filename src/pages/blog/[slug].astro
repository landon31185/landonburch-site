---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts: share at least one tag, exclude current
const allPosts = await getCollection('blog');
const related = allPosts
  .filter(p =>
    p.id !== post.id &&
    p.data.tags.some(t => post.data.tags.includes(t))
  )
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

function formatDate(d) {
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---
<BaseLayout title={`${post.data.title} — Landon Burch`} description={post.data.description}>

  <article class="post-article">

    <header class="post-header">
      <div class="container--narrow">
        <div class="post-meta">
          <a href="/blog" class="back-link">&larr; Writing</a>
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        </div>
        <h1 class="post-heading">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <div class="post-body container--narrow">
      <div class="prose">
        <Content />
      </div>
    </div>

    {post.data.showNotes && post.data.showNotes.length > 0 && (
      <aside class="show-notes container--narrow">
        <h2 class="show-notes-title">Show notes &amp; links</h2>
        <ul class="show-notes-list">
          {post.data.showNotes.map(note => (
            <li>
              <a href={note.url} target="_blank" rel="noopener noreferrer">{note.label}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    {related.length > 0 && (
      <section class="related container--narrow">
        <h2 class="related-title">Related posts</h2>
        <div class="related-grid">
          {related.map(p => (
            <a href={`/blog/${p.id}`} class="related-card">
              <span class="related-date">{formatDate(p.data.date)}</span>
              <h3 class="related-heading">{p.data.title}</h3>
            </a>
          ))}
        </div>
      </section>
    )}

  </article>

</BaseLayout>

<style>
  .post-article {
    padding-bottom: var(--space-24);
  }

  .post-header {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .back-link {
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-text); }

  .post-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-body {
    margin-bottom: var(--space-16);
  }

  /* Show notes */
  .show-notes {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .show-notes-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    font-weight: 400;
  }

  .show-notes-list {
    list-style: disc;
    padding-left: var(--space-6);
  }

  .show-notes-list li {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
  }

  .show-notes-list a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Related */
  .related {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .related-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    font-weight: 400;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: var(--color-bg);
    text-decoration: none;
    transition: background 0.15s;
  }

  .related-card:hover { background: var(--color-surface); }

  .related-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .related-heading {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>

---
import '../styles/global.css';

const { title = 'Landon Burch', description = 'UX Designer & Systems Thinker' } = Astro.props;
const pathname = Astro.url.pathname;

function isActive(href) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body>

  <nav>
    <a href="/" class="nav-mark">Landon</a>
    <ul class="nav-links">
      <li><a href="/blog" class:list={[{ active: isActive('/blog') }]}>Writing</a></li>
      <li><a href="/lab"  class:list={[{ active: isActive('/lab') }]}>Lab</a></li>
      <li><a href="#">Work</a></li>
      <li><a href="#">About</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <span>Landon Burch</span>
    <span>UX Designer · Systems Thinker</span>
  </footer>

</body>
</html>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    padding: 1.5rem 3rem;
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
  }

  .nav-mark {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--color-text);
    text-decoration: none;
    pointer-events: all;
    mix-blend-mode: multiply;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 2.5rem;
    list-style: none;
    pointer-events: all;
  }

  .nav-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.45;
    transition: opacity 0.2s;
    mix-blend-mode: multiply;
  }

  .nav-links a:hover,
  .nav-links a.active { opacity: 1; }

  main {
    min-height: 100vh;
  }

  footer {
    background: var(--color-ink-bg);
    border-top: 1px solid var(--color-ink-border);
    padding: 2.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  footer span {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: var(--color-ink-muted);
    opacity: 0.35;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    nav     { padding: 1.2rem 1.5rem; }
    .nav-links { gap: 1.5rem; }
    footer  { padding: 2rem 1.5rem; flex-direction: column; gap: 0.5rem; }
  }
</style>
